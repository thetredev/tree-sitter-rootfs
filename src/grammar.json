{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "rootfs",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_statement"
      }
    },
    "_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "imports_stmt"
        },
        {
          "type": "SYMBOL",
          "name": "assignment"
        },
        {
          "type": "SYMBOL",
          "name": "block_def"
        }
      ]
    },
    "comment": {
      "type": "PATTERN",
      "value": "#[^\\n]*"
    },
    "imports_stmt": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "imports"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "import_path"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "import_path": {
      "type": "PATTERN",
      "value": "[a-zA-Z0-9_.][a-zA-Z0-9_.\\/-]*(?:\\/\\*|\\*)?(?:[ \\t]*![ \\t]*[a-zA-Z0-9_.,-]+)?"
    },
    "assignment": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "SYMBOL",
          "name": "_value"
        }
      ]
    },
    "_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "scalar"
        },
        {
          "type": "SYMBOL",
          "name": "list"
        }
      ]
    },
    "scalar": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "bare_string"
        }
      ]
    },
    "string": {
      "type": "PATTERN",
      "value": "\"[^\"\\\\]*(?:\\\\.[^\"\\\\]*)*\""
    },
    "bare_string": {
      "type": "PATTERN",
      "value": "(?:\\$\\{[^}\\s]*\\}|[^\\s\\[\\]={}#\"])+"
    },
    "list": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "bare_string"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "block_def": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "block_content_line"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_block_end"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r\\n]"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "block_content_line"
    },
    {
      "type": "SYMBOL",
      "name": "_block_end"
    }
  ],
  "inline": [],
  "supertypes": []
}
